# ===========================================
# SIMS - Student Internship Management System
# ===========================================
# Environment Configuration Template
# Copy this file to .env and update values

# Application Settings
APP_NAME="SIMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP Workers (for development)
# PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# Database Configuration
# ===========================================
# For production, use MySQL:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sims
DB_USERNAME=root
DB_PASSWORD=

# For development/testing, you can use SQLite:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# ===========================================
# Session Configuration
# ===========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ===========================================
# Queue Configuration
# ===========================================
# Use 'database' for production (recommended)
# Use 'sync' for development without queue worker
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ===========================================
# Cache & Filesystem
# ===========================================
CACHE_STORE=database
# CACHE_PREFIX=sims_
FILESYSTEM_DISK=local

# ===========================================
# Redis Configuration (optional)
# ===========================================
# Enable Redis for better performance in production
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# Email Configuration
# ===========================================
# For development, use 'log' to write emails to logs
# For production, configure SMTP settings below
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@sims.test"
MAIL_FROM_NAME="${APP_NAME}"

# Production SMTP Example (Gmail):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls

# ===========================================
# AWS S3 Configuration (optional)
# ===========================================
# For file storage in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# Memcached (optional)
# ===========================================
MEMCACHED_HOST=127.0.0.1

# ===========================================
# Frontend Build
# ===========================================
VITE_APP_NAME="${APP_NAME}"

# ===========================================
# SIMS Custom Settings
# ===========================================
# Academic Year (used in reports)
SIMS_ACADEMIC_YEAR="2024/2025"

# Maximum file upload size (in KB)
SIMS_MAX_UPLOAD_SIZE=5120

# Allowed document types
SIMS_ALLOWED_DOC_TYPES="pdf,doc,docx,jpg,jpeg,png"
